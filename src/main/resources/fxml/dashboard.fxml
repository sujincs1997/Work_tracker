<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.worktracker.controller.DashboardController">
    <VBox spacing="20.0" style="-fx-background-color: transparent;">
        <padding>
            <Insets bottom="10.0" left="5.0" right="10.0" top="5.0"/>
        </padding>

        <!-- Stat Cards Grid -->
        <GridPane hgap="15.0" vgap="15.0">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" minWidth="150.0" percentWidth="25.0" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="150.0" percentWidth="25.0" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="150.0" percentWidth="25.0" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="150.0" percentWidth="25.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="100.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="100.0" vgrow="SOMETIMES" />
            </rowConstraints>

            <!-- Card 1: Today's Hours -->
            <VBox styleClass="card" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label text="Today's Hours" styleClass="card-title" />
                <Label fx:id="lblTodayHours" text="0.0 hrs" styleClass="card-value" />
                <ProgressBar fx:id="progressToday" progress="0.0" maxWidth="Infinity" style="-fx-padding: 5 0 0 0;" />
            </VBox>

            <!-- Card 2: Weekly Hours -->
            <VBox styleClass="card" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="Weekly Hours" styleClass="card-title" />
                <Label fx:id="lblWeeklyHours" text="0.0 hrs" styleClass="card-value" />
                <ProgressBar fx:id="progressWeekly" progress="0.0" maxWidth="Infinity" style="-fx-padding: 5 0 0 0;" />
            </VBox>

            <!-- Card 3: Monthly Hours -->
            <VBox styleClass="card" GridPane.columnIndex="2" GridPane.rowIndex="0">
                <Label text="Monthly Hours" styleClass="card-title" />
                <Label fx:id="lblMonthlyHours" text="0.0 hrs" styleClass="card-value" />
                <ProgressBar fx:id="progressMonthly" progress="0.0" maxWidth="Infinity" style="-fx-padding: 5 0 0 0;" />
            </VBox>

            <!-- Card 4: Productivity -->
            <VBox styleClass="card" GridPane.columnIndex="3" GridPane.rowIndex="0">
                <Label text="Productivity" styleClass="card-title" />
                <Label fx:id="lblProductivity" text="0.0%" styleClass="card-value" />
                <ProgressBar fx:id="progressProductivity" progress="0.0" maxWidth="Infinity" style="-fx-padding: 5 0 0 0;" />
            </VBox>

            <!-- Card 5: Pending Tasks -->
            <VBox styleClass="card" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <Label text="Pending Tasks" styleClass="card-title" />
                <Label fx:id="lblPendingTasks" text="0" styleClass="card-value" style="-fx-text-fill: -warning;" />
            </VBox>

            <!-- Card 6: Completed Tasks -->
            <VBox styleClass="card" GridPane.columnIndex="1" GridPane.rowIndex="1">
                <Label text="Completed Tasks" styleClass="card-title" />
                <Label fx:id="lblCompletedTasks" text="0" styleClass="card-value" style="-fx-text-fill: -success;" />
            </VBox>

            <!-- Card 7: Completion % -->
            <VBox styleClass="card" GridPane.columnIndex="2" GridPane.rowIndex="1">
                <Label text="Completion %" styleClass="card-title" />
                <Label fx:id="lblCompletionPercent" text="0.0%" styleClass="card-value" />
            </VBox>

            <!-- Card 8: Active Timer Mini Panel -->
            <VBox styleClass="card" GridPane.columnIndex="3" GridPane.rowIndex="1" alignment="CENTER_LEFT">
                <Label text="Active Task Timer" styleClass="card-title" />
                <Label fx:id="lblActiveTimer" text="00:00:00" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: -primary-color;" />
            </VBox>
        </GridPane>

        <!-- Lower Section: Active Timer Control & Recent Activities -->
        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
            <!-- Active Timer Panel -->
            <VBox spacing="15.0" styleClass="card" HBox.hgrow="ALWAYS" prefWidth="400.0">
                <Label text="Task Timer Console" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                <Separator />
                
                <Label text="Select Task to Track:" style="-fx-font-weight: bold;" />
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <ComboBox fx:id="comboActiveTask" promptText="Select a task..." HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                    <Button text="⚡ Quick Track" onAction="#handleQuickNewTask" styleClass="btn-success" style="-fx-font-size: 11px;" />
                </HBox>
                
                <Label text="Select Sub-Process (Optional):" style="-fx-font-weight: bold;" />
                <ComboBox fx:id="comboActiveProcess" promptText="Select a process..." maxWidth="Infinity" />

                <HBox alignment="CENTER" spacing="20.0" style="-fx-padding: 10 0;">
                    <Label fx:id="lblConsoleTimer" text="00:00:00" style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: -primary-color;" />
                </HBox>
                
                <HBox spacing="10.0" alignment="CENTER">
                    <Button fx:id="btnStart" text="▶ Start" styleClass="btn-primary" onAction="#handleStartTimer" prefWidth="100.0" />
                    <Button fx:id="btnPause" text="⏸ Pause" onAction="#handlePauseTimer" prefWidth="100.0" />
                    <Button fx:id="btnResume" text="⏯ Resume" onAction="#handleResumeTimer" prefWidth="100.0" />
                    <Button fx:id="btnStop" text="⏹ Stop" styleClass="btn-danger" onAction="#handleStopTimer" prefWidth="100.0" />
                </HBox>

                <VBox spacing="5.0">
                    <Label text="Timer Details:" style="-fx-font-weight: bold;" />
                    <GridPane hgap="10.0" vgap="5.0">
                        <Label text="Working Time:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: -text-muted;" />
                        <Label fx:id="lblTimerWorking" text="00:00:00" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        
                        <Label text="Break Time:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: -text-muted;" />
                        <Label fx:id="lblTimerBreak" text="00:00:00" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        
                        <Label text="Idle Time:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: -text-muted;" />
                        <Label fx:id="lblTimerIdle" text="00:00:00" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                    </GridPane>
                </VBox>
                
                <TextArea fx:id="txtTimerNotes" promptText="Enter notes for this timer session..." prefHeight="70.0" wrapText="true" />
            </VBox>

            <!-- Activity Logs / Timeline -->
            <VBox spacing="15.0" styleClass="card" HBox.hgrow="ALWAYS">
                <Label text="Daily Activity Log" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                <Separator />
                <ListView fx:id="listActivities" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background-insets: 0; -fx-padding: 0;" />
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
